import tkinter as tk
from tkinter import messagebox
from datetime import datetime
def say_hello():
    messagebox.showinfo("Jarvis", "Hello Sir! How can I help you?")
def show_time():
    current_time = datetime.now().strftime("%I:%M:%S %p")
    messagebox.showinfo("Time", f"Current Time:\n{current_time}")
def show_date():
    current_date = datetime.now().strftime("%d-%m-%Y")
    messagebox.showinfo("Date", f"Today's Date:\n{current_date}")
def exit_app():
    root.destroy()
root = tk.Tk()
root.title("Jarvis Control Panel")
root.geometry("400x300")
root.resizable(False, False)
title_label = tk.Label(
    root,
    text="JARVIS CONTROL PANEL",
    font=("Arial", 16)
)
title_label.pack(pady=20)
hello_button = tk.Button(
    root,
    text="Say Hello",
    font=("Arial", 12),
    command=say_hello
)
hello_button.pack(pady=5)
time_button = tk.Button(
    root,
    text="Show Time",
    font=("Arial", 12),
    command=show_time
)
time_button.pack(pady=5)
date_button = tk.Button(
    root,
    text="Show Date",
    font=("Arial", 12),
    command=show_date
)
date_button.pack(pady=5)
exit_button = tk.Button(
    root,
    text="Exit",
    font=("Arial", 12),
    command=exit_app
)
exit_button.pack(pady=5)
root.mainloop()